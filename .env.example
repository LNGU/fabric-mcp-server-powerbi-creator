# Fabric MCP Server Configuration
# Copy this file to .env and fill in your values

# Fabric Workspace (from URL: app.fabric.microsoft.com/groups/{WORKSPACE_ID}/...)
FABRIC_WORKSPACE_ID=your-workspace-guid

# Lakehouse ID (from Lakehouse URL)
FABRIC_LAKEHOUSE_ID=your-lakehouse-guid

# Azure DevOps Repository
ADO_REPO_URL=https://dev.azure.com/your-org/your-project/_git/your-repo
ADO_BRANCH=main

# Optional: Service Principal Authentication (for CI/CD)
# FABRIC_TENANT_ID=your-tenant-id
# FABRIC_CLIENT_ID=your-client-id
# FABRIC_CLIENT_SECRET=your-client-secret
